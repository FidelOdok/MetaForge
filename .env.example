# MetaForge — Local development environment variables
# Copy to .env and customize as needed:  cp .env.example .env

# ── Dashboard ────────────────────────────────────────────────────
DASHBOARD_PORT=3000

# ── Gateway ───────────────────────────────────────────────────────
GATEWAY_PORT=8000
METAFORGE_ENV=docker

# ── Neo4j ─────────────────────────────────────────────────────────
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=metaforge

# ── Kafka ─────────────────────────────────────────────────────────
KAFKA_PORT=9092

# ── Temporal ──────────────────────────────────────────────────────
TEMPORAL_PORT=7233
TEMPORAL_UI_PORT=8080

# ── Observability (only used with --profile observability) ────────
GRAFANA_PASSWORD=metaforge

# ── MCP HTTP sidecar (dev) ────────────────────────────────────────
# Static API key guarding the HTTP MCP transport (MET-338). Leave empty
# for LAN-only open mode; set a strong value before exposing :8765 via
# the Cloudflare tunnel below. Clients send it as `Authorization: Bearer`.
# Works for Claude Code; the claude.ai web connector needs OAuth (below).
METAFORGE_MCP_API_KEY=

# ── MCP OAuth 2.1 + PKCE (MET-480) ────────────────────────────────
# Required for the claude.ai web connector, which can't send a static
# bearer header. Setting METAFORGE_OAUTH_LOGIN_SECRET turns the OAuth
# authorization server ON; /authorize is gated by this shared secret.
# Leave empty to keep OAuth off (Claude Code + static key still work).
METAFORGE_OAUTH_LOGIN_SECRET=
# Public HTTPS base URL claude.ai reaches the server at, e.g.
# https://mcp.yourdomain.com. If unset, it's derived from the
# X-Forwarded-* headers Cloudflare sets — set it explicitly if discovery
# misbehaves behind other proxies.
METAFORGE_OAUTH_ISSUER=
# Optional: actor id stamped on issued tokens (default oauth:web) and
# token lifetimes in seconds (defaults: access 3600, refresh 30d).
# METAFORGE_OAUTH_ACTOR_ID=oauth:web
# METAFORGE_OAUTH_ACCESS_TTL=3600

# ── Cloudflare tunnel (MET-482) ───────────────────────────────────
# Token for the named tunnel that fronts mcp-http and gives Claude cloud
# a stable public HTTPS endpoint. Create the tunnel in the Cloudflare
# Zero Trust dashboard (Networks → Tunnels) and paste its token here.
# Route the tunnel's Public Hostname to HTTP http://mcp-http:8765.
# See docs/runbooks/cloudflare-mcp-tunnel.md.
CLOUDFLARE_TUNNEL_TOKEN=
