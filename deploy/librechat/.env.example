# LibreChat env for MetaForge (MET-552) — copy to deploy/librechat/.env and fill in.
# deploy/librechat/.env is gitignored; never commit real keys.

# --- LLM provider keys (LibreChat calls providers directly) -----------
# At least one is required to actually chat. MetaForge exposes no
# OpenAI-compatible endpoint, so these are LibreChat's own keys.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- LibreChat secrets ------------------------------------------------
# Generate strong random values. Quick recipe:
#   CREDS_KEY:            openssl rand -hex 32   (64 hex chars)
#   CREDS_IV:             openssl rand -hex 16   (32 hex chars)
#   JWT_SECRET:           openssl rand -hex 32
#   JWT_REFRESH_SECRET:   openssl rand -hex 32
# Or use the official generator: https://www.librechat.ai/toolkit/creds_generator
CREDS_KEY=
CREDS_IV=
JWT_SECRET=
JWT_REFRESH_SECRET=

# --- MetaForge MCP auth (optional) ------------------------------------
# Only needed if the mcp-http sidecar enforces auth (METAFORGE_MCP_API_KEY
# set on the sidecar). Leave blank for open-mode dev. Referenced by
# librechat.yaml's mcpServers.metaforge.headers when uncommented.
METAFORGE_MCP_API_KEY=
