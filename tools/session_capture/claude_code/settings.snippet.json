{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "mcp__metaforge__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/tools/session_capture/claude_code_adapter.py\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/tools/session_capture/claude_code_adapter.py\""
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/tools/session_capture/claude_code_adapter.py\""
          }
        ]
      }
    ]
  }
}
